<!-- filepath: views/employees/scheduleEmployee.hbs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lịch trực của nhân viên</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/scheduleEmployee.css">
</head>
<body>
    <div class="layout-wrapper">
        {{> sidebar}}
        <div class="schedule p-4">
            <h2>Lịch trực của nhân viên: {{employee.name}}</h2>
            
            <!-- Employee Info Table -->
            <h3>Thông tin nhân viên</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên</th>
                        <th>Vai trò</th>
                        <th>Hệ số lương</th>
                    </tr>
                </thead>
                <tbody id="employeeInfoTableBody" data-employee='{{json employee}}'>
                    <tr>
                        <td>{{employee.employee_id}}</td>
                        <td>{{employee.name}}</td>
                        <td>{{employee.role}}</td>
                        <td>{{employee.salary_coefficient}}</td>
                    </tr>
                </tbody>
            </table>

            <!-- Shift Schedule Table -->
            <h3>Ca trực</h3>
            <button type="button" class="btn btn-primary mb-3" onclick="openAddModal()">Thêm lịch trực</button>
            <table class="table" id="shiftTable">
                <thead>
                    <tr>
                        <th>Ngày trực</th>
                        <th>Ca trực</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody id="shiftTableBody">
                    {{#each employee.schedule}}
                    <tr>
                        <td>{{this.date}}</td>
                        <td>{{this.shift}}</td>
                        <td>
                            <button class="btn btn-warning btn-sm" onclick="openEditModal({{@index}})">Sửa</button>
                            <button class="btn btn-danger btn-sm" onclick="openDeleteModal({{@index}})">Xóa</button>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <!-- Pagination -->
            <div class="d-flex justify-content-center align-items-center mt-3">
                <button class="btn btn-secondary btn-sm me-2" id="prevPageBtn">&laquo;</button>
                <button class="btn btn-secondary btn-sm me-2" id="prevBtn">&lt;</button>
                <span><span id="currentPage">1</span>/<span id="totalPages">1</span></span>
                <button class="btn btn-secondary btn-sm ms-2" id="nextBtn">&gt;</button>
                <button class="btn btn-secondary btn-sm ms-2" id="nextPageBtn">&raquo;</button>
            </div>

            <!-- Update modal title to be dynamic -->
            <div class="modal fade" id="scheduleModal">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="scheduleModalLabel">Thêm lịch trực</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <form id="scheduleForm">
                                <div class="mb-3">
                                    <label for="shiftDate" class="form-label">Ngày trực</label>
                                    <input type="date" class="form-control" id="shiftDate" required>
                                </div>
                                <div class="mb-3">
                                    <label for="shift" class="form-label">Ca trực</label>
                                    <select class="form-select" id="shift" required>
                                        <option value="Morning">Sáng</option>
                                        <option value="Afternoon">Chiều</option>
                                        <option value="Evening">Tối</option>
                                        <option value="Night">Khuya</option>
                                    </select>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                            <button type="button" class="btn btn-primary" onclick="saveSchedule()">Lưu</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Delete Modal -->
            <div class="modal fade" id="deleteModal">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Xóa lịch trực</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p>Bạn có chắc chắn muốn xóa lịch trực này không?</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="button" class="btn btn-danger" onclick="deleteSchedule()">Xóa</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/scheduleEmployee.js"></script>
</body>
</html>