<!-- filepath: views/users/userList.hbs -->
<div class="layout-wrapper">
    {{> sidebar}}
    <div class="user-list p-4">
        <h2>Danh sách người dùng</h2>
        <div class="d-flex justify-content-end mb-3">
            <div class="input-group" style="width: 30%;">
                <input type="text" class="form-control" id="searchUser" placeholder="Tìm kiếm theo tên, email, số điện thoại">
                <button class="btn btn-outline-secondary" id="searchBtn">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody id="userTableBody">
                {{#each users}}
                <tr>
                    <td>{{this.customer_id}}</td>
                    <td>{{this.name}}</td>
                    <td>{{this.email}}</td>
                    <td>{{this.phone}}</td>
                    <td>
                        <button class="btn btn-warning btn-sm" onclick="viewTransactionHistory('{{this.customer_id}}')">
                            <i class="bi bi-receipt-cutoff"></i> Lịch sử giao dịch
                        </button>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <!-- Pagination -->
        <div class="d-flex justify-content-center align-items-center mt-3">
            <button class="btn btn-secondary btn-sm me-2" id="prevPageBtn">&laquo;</button>
            <button class="btn btn-secondary btn-sm me-2" id="prevBtn">&lt;</button>
            <span><span id="currentPage">1</span>/<span id="totalPages">1</span></span>
            <button class="btn btn-secondary btn-sm ms-2" id="nextBtn">&gt;</button>
            <button class="btn btn-secondary btn-sm ms-2" id="nextPageBtn">&raquo;</button>
        </div>
    </div>
</div>

<script src="/js/userList.js"></script>