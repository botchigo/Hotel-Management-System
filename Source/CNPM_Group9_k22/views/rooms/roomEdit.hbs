<div class="layout-wrapper">
    {{> sidebar}}
    <div class="room-edit p-4">
        <h3>Chỉnh Sửa Phòng</h3>
        <form action="/rooms/edit/{{room.room_id}}" method="POST">
            <div class="mb-3">
                <label for="type" class="form-label">Loại Phòng</label>
                <div class="d-flex">
                    <div class="form-check me-4">
                        <input class="form-check-input" type="radio" name="type" id="single" value="Single" {{#if (eq room.type "Single")}}checked{{/if}} required>
                        <label class="form-check-label" for="single">Single</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="radio" name="type" id="double" value="Double" {{#if (eq room.type "Double")}}checked{{/if}}>
                        <label class="form-check-label" for="double">Double</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="radio" name="type" id="suite" value="Suite" {{#if (eq room.type "Suite")}}checked{{/if}}>
                        <label class="form-check-label" for="suite">Suite</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="type" id="family" value="Family" {{#if (eq room.type "Family")}}checked{{/if}}>
                        <label class="form-check-label" for="family">Family</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="price" class="form-label">Giá Phòng/ngày (VNĐ)</label>
                <input type="number" class="form-control" id="price" name="price" value="{{room.price}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Tiện Ích</label>
                <div class="d-flex flex-wrap">
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="TV" id="tv" {{#if (includes room.amenities "TV")}}checked{{/if}}>
                        <label class="form-check-label" for="tv">TV</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="Fridge" id="fridge" {{#if (includes room.amenities "Fridge")}}checked{{/if}}>
                        <label class="form-check-label" for="fridge">Tủ lạnh</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="WiFi" id="wifi" {{#if (includes room.amenities "WiFi")}}checked{{/if}}>
                        <label class="form-check-label" for="wifi">WiFi</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="Safe" id="safe" {{#if (includes room.amenities "Safe")}}checked{{/if}}>
                        <label class="form-check-label" for="safe">Két Sắt</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="LargeCabinet" id="large_cabinet" {{#if (includes room.amenities "LargeCabinet")}}checked{{/if}}>
                        <label class="form-check-label" for="large_cabinet">Tủ Lớn</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="amenities" value="SmallCabinet" id="small_cabinet" {{#if (includes room.amenities "SmallCabinet")}}checked{{/if}}>
                        <label class="form-check-label" for="small_cabinet">Tủ Nhỏ</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="status" class="form-label">Trạng thái</label>
                <select class="form-select" id="status" name="status" required>
                    <option value="Đang có sẵn" {{#if (eq room.status "Đang có sẵn")}}selected{{/if}}>Đang có sẵn</option>
                    <option value="Đang bảo trì" {{#if (eq room.status "Đang bảo trì")}}selected{{/if}}>Đang bảo trì</option>
                    <option value="Đã chọn" {{#if (eq room.status "Đã chọn")}}selected{{/if}}>Đã chọn</option>
                    <option value="Đã đặt" {{#if (eq room.status "Đã đặt")}}selected{{/if}}>Đã đặt</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Cập Nhật Phòng</button>
        </form>
        <form action="/rooms/delete/{{room.room_id}}" method="POST" style="display:inline;">
            <button type="button" class="btn btn-danger mt-2" id="delete-room-btn">Xóa Phòng</button>
        </form>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <strong class="me-auto">Thông báo</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body">
            <!-- Success message will be inserted here -->
        </div>
    </div>
</div>

<script src="/js/roomEdit.js"></script>