<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách phòng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/roomList.css">
    <link rel="stylesheet" href="/css/customerSidebar.css">
</head>
<body>
    <div class="layout-wrapper">
        {{> customerSidebar}}
        <div class="room-list p-4">
            <input type="hidden" id="customerId" value="{{customerId}}">
            <h2>Danh sách phòng</h2>
            <div class="d-flex justify-content-between mb-3">
                <div class="d-flex align-items-center">
                    <button class="btn btn-primary me-2" id="filterAvailableBtn">Lọc phòng trống</button>
                </div>
                <div class="input-group" style="width: 40%;">
                    <input type="text" class="form-control" id="searchRoom" placeholder="Tìm kiếm theo từ khóa">
                    <button class="btn btn-outline-secondary" id="searchBtn">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Room ID</th>
                        <th>Loại phòng</th>
                        <th>Giá Phòng/ngày (VNĐ)</th>
                        <th>Tiện ích</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody id="roomTableBody">
                    {{#each rooms}}
                    <tr>
                        <td>{{this.room_id}}</td>
                        <td>{{this.type}}</td>
                        <td>{{this.price}}</td>
                        <td>{{this.amenities}}</td>
                        <td>{{this.status}}</td>
                        <td>
                            {{#if (eq this.status "Đang có sẵn")}}
                                <button class="btn btn-primary" onclick="bookRoom('{{this.room_id}}');">Đặt phòng</button>
                            {{else}}
                                <button class="btn btn-secondary" disabled>Không khả dụng</button>
                            {{/if}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            <div class="d-flex justify-content-center align-items-center mt-3">
                <button class="btn btn-secondary btn-sm me-2" id="prevPageBtn">&laquo;</button>
                <button class="btn btn-secondary btn-sm me-2" id="prevBtn">&lt;</button>
                <span id="currentPage">1</span>/<span id="totalPages">1</span>
                <button class="btn btn-secondary btn-sm ms-2" id="nextBtn">&gt;</button>
                <button class="btn btn-secondary btn-sm ms-2" id="nextPageBtn">&raquo;</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/customerRoomList.js"></script>
</body>
</html>