<div class="layout-wrapper">
    {{> sidebar}}
    <div class="room-list p-4">
        <h2>Danh sách phòng</h2>
        <div class="d-flex justify-content-between mb-3">
            <div class="input-group" style="width: 40%;">
                <input type="text" class="form-control" id="searchRoom" placeholder="Tìm kiếm theo từ khóa">
                <button class="btn btn-outline-secondary" id="searchBtn">
                    <i class="bi bi-search"></i>
                </button>
            </div>
            <div class="d-flex align-items-center">
                <select class="form-select me-2" id="filterType">
                    <option value="">Loại phòng</option>
                    <option value="Single">Single</option>
                    <option value="Double">Double</option>
                    <option value="Suite">Suite</option>
                    <option value="Family">Family</option>
                </select>
                <input type="number" class="form-control me-2" id="filterPrice" placeholder="Giá tối đa (VND)">
                <button class="btn btn-primary" id="filterBtn">Lọc</button>
            </div>
        </div>
        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Room ID</th>
                    <th>Loại phòng</th>
                    <th>Giá Phòng/ngày (VNĐ)</th>
                    <th>Tiện ích</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody id="roomTableBody">
                {{#each rooms}}
                <tr>
                    <td>{{this.room_id}}</td>
                    <td>{{this.type}}</td>
                    <td>{{this.price}}</td>
                    <td>{{this.amenities}}</td>
                    <td>{{this.status}}</td>
                    <td>
                        <a href="/rooms/edit/{{this.room_id}}" class="btn btn-primary">Chỉnh sửa</a>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        <div class="d-flex justify-content-center align-items-center mt-3">
            <button class="btn btn-secondary btn-sm me-2" id="prevPageBtn">&laquo;</button>
            <button class="btn btn-secondary btn-sm me-2" id="prevBtn">&lt;</button>
            <span id="currentPage">1</span>/<span id="totalPages">1</span>
            <button class="btn btn-secondary btn-sm ms-2" id="nextBtn">&gt;</button>
            <button class="btn btn-secondary btn-sm ms-2" id="nextPageBtn">&raquo;</button>
        </div>
    </div>
</div>