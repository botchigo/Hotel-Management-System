<div class="layout-wrapper">
    {{> sidebar}}
    <div class="room-add p-4">
        <h3>Thêm Phòng</h3>
        <form action="/rooms/add" method="POST">
            <div class="mb-3">
                <label for="type" class="form-label">Loại Phòng</label>
                <div class="d-flex">
                    <div class="form-check me-4">
                        <input class="form-check-input" type="radio" name="type" id="single" value="Single" required>
                        <label class="form-check-label" for="single">Single</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="radio" name="type" id="double" value="Double">
                        <label class="form-check-label" for="double">Double</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="radio" name="type" id="suite" value="Suite">
                        <label class="form-check-label" for="suite">Suite</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="type" id="family" value="Family">
                        <label class="form-check-label" for="family">Family</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="price" class="form-label">Giá Phòng/ngày (VNĐ)</label>
                <input type="number" class="form-control" id="price" name="price" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Tiện Ích</label>
                <div class="d-flex flex-wrap">
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="TV" id="tv">
                        <label class="form-check-label" for="tv">TV</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="Fridge" id="fridge">
                        <label class="form-check-label" for="fridge">Tủ lạnh</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="WiFi" id="wifi">
                        <label class="form-check-label" for="wifi">WiFi</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="Safe" id="safe">
                        <label class="form-check-label" for="safe">Két Sắt</label>
                    </div>
                    <div class="form-check me-4">
                        <input class="form-check-input" type="checkbox" name="amenities" value="LargeCabinet" id="large_cabinet">
                        <label class="form-check-label" for="large_cabinet">Tủ Lớn</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="amenities" value="SmallCabinet" id="small_cabinet">
                        <label class="form-check-label" for="small_cabinet">Tủ Nhỏ</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="status" class="form-label">Trạng thái</label>
                <select class="form-select" id="status" name="status" required>
                    <option value="Đang có sẵn">Đang có sẵn</option>
                    <option value="Đang bảo trì">Đang bảo trì</option>
                    <option value="Đã chọn">Đã chọn</option>
                    <option value="Đã đặt">Đã đặt</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Thêm Phòng</button>
        </form>
    </div>
</div>