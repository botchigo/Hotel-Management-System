<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-12">
                <h2 class="text-center mb-4">Đăng nhập</h2>
                {{#if error}}
                    <div class="alert alert-danger">{{error}}</div>
                {{/if}}
                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label for="role" class="form-label">Bạn đăng nhập với vai trò gì?</label>
                        <select class="form-select" id="role" name="role" onchange="showForm()" required>
                            <option value="" selected disabled>Chọn vai trò để tiếp tục</option>
                            <option value="customer">Khách hàng</option>
                            <option value="manager">Quản lý</option>
                        </select>
                    </div>

                    <!-- Customer Form -->
                    <div id="customer-form" class="form-section">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="Nhập email">
                        </div>
                        <div class="mb-3">
                            <label for="customer-password" class="form-label">Mật khẩu</label>
                            <input type="password" class="form-control" id="customer-password" name="customerPassword" placeholder="Nhập mật khẩu">
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Đăng nhập</button>
                        </div>
                        <div class="mt-3 text-center">
                            <p>Chưa có tài khoản? <a href="/register">Đăng ký</a></p>
                        </div>
                    </div>

                    <!-- Manager Form -->
                    <div id="manager-form" class="form-section">
                        <div class="mb-3">
                            <label for="manager-username" class="form-label">Tên tài khoản</label>
                            <input type="text" class="form-control" id="manager-username" name="username" placeholder="Nhập tên tài khoản">
                        </div>
                        <div class="mb-3">
                            <label for="manager-password" class="form-label">Mật khẩu</label>
                            <input type="password" class="form-control" id="manager-password" name="managerPassword" placeholder="Nhập mật khẩu">
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Đăng nhập</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showForm() {
            const role = document.getElementById('role').value;
            const customerForm = document.getElementById('customer-form');
            const managerForm = document.getElementById('manager-form');
            
            // Hide all forms first
            customerForm.style.display = 'none';
            managerForm.style.display = 'none';
            
            // Show selected form
            if (role === 'customer') {
                customerForm.style.display = 'block';
            } else if (role === 'manager') {
                managerForm.style.display = 'block';
            }
        }

        // Show error notification if present
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            const message = urlParams.get('message');
            if (message) {
                alert(message);
            }
            showForm(); // Ensure the correct form is shown on page load
        };
    </script>
</body>
</html>